# EditorConfig helps maintain consistent coding styles across different editors
# Visit editorconfig.org for more information

root = true

# Apply to all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# JavaScript/TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2
max_line_length = 100

# JSON
[*.json]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# SQL
[*.sql]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Gradle
[*.gradle]
indent_size = 4

# iOS Xcode
[*.{pbxproj,xcworkspacedata,xcscheme}]
indent_size = 3
indent_style = tab

# Android XML
[*.xml]
indent_size = 4